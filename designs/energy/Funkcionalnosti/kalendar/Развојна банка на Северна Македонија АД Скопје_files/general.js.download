var iBank = iBank || {};
var formId_Payment = '';
var lg_md_border = 1283;
iBank.Forms = new function () {
    var currentLanguage = 'mk',
        currentRootUrl = '',
        currentForm = '',
        currentItem = '',
        init = function (language, rootUrl) {
            document.onhelp = new Function("return false;");
            window.onhelp = new Function("return false;");
            var browser = navigator.userAgent;
            //if (browser.search(/msie|opera|safari/i) != -1)
            // document.onkeydown = keyHit;
            //else
            //   document.onkeypress = keyHit;
            $(document).on('click', '#checkAll', function () {
                if ($(this).is(':checked'))
                    $('.col-paymentorders-check .ace').prop('checked', true);
                else
                    $('.col-paymentorders-check .ace').prop('checked', false);
                markChecked();
            });
            $(document).on('click', '.ace', function () {
                markChecked();
            });
            currentLanguage = language;
            currentRootUrl = rootUrl;
            $('[data-toggle=disable]').on('click', function () {
                $(this).attr('disabled', 'disabled');
            });
            $('a[data-original-title]').tooltip();
            $("[data-toggle=tooltip]").tooltip();
            $("[data-toggle=tooltipbody]").tooltip({ container: 'body' });
            $("body").tooltip({ selector: '[data-toggle=tooltip]' });
            $("body").tooltip({ selector: '[data-toggle=tooltipbody]', container: 'body' });
            /*$('.date-picker').datepicker({
                todayHighlight: true,
                autoclose: true,
                language: currentLanguage
            })
                .mask('11.11.1111')
                .next().css('cursor', 'pointer').on(ace.click_event, function () {
                    $(this).prev().datepicker('show');
                    $('.datepicker').css('z-index', '1060');

                });*/
            toggleFilter();
            toggleUserTemplates();
            $(window).on('resize', function () {
                iBank.Forms.ToggleFilter();
                iBank.Forms.ToggleUserTemplates();
            });
            $('.purple .dropdown-menu .btn-empty').on({
                "click": function (e) {
                    if (!$(this).hasClass('btn-success')) {
                        e.stopPropagation();
                        e.preventDefault();
                        var button = $(this);
                        button.addClass('disabled');
                        $.ajax({
                            url: currentRootUrl + "Home/UpdateNotificationStatus",
                            data: { notificationId: $(this).attr('id') },
                            type: "POST",
                            cache: false,
                            success: function () {
                                button.removeClass('disabled');
                                button.addClass('btn-success');
                            }
                        });
                    }
                }
            });
            $('.submenu a, .sidebar-shortcuts a, .show-wait-window').on('click', function () {
                blockPage();
            });
        },
        keyHit = function (event) {
            console.log(event.keyCode);
            var browser = navigator.userAgent;
            var keyStruck;
            if (browser.search(/msie|safari/i) != -1)
                keyStruck = window.event.keyCode;
            else
                keyStruck = event.keyCode;
            if (keyStruck == 112) {
                if (browser.search(/msie/i) == -1 && browser.search("Trident/7.") == -1) {
                    event.stopPropagation();
                    event.preventDefault();
                    console.log(currentItem);
                    angular.element('[ng-controller=HelpController]').scope().showHelp(currentItem);
                }
            }
        },
        blockPage = function () {
            $('#pageOverlay').modal({
                keyboard: false
            });
        },
        unblockPage = function () {
            $('#pageOverlay').modal('hide');
        },
        markChecked = function () {
            var transactions = '';
            $('.col-paymentorders-check .ace').each(function () {
                if ($(this).is(':checked'))
                    transactions += $(this).val() + ',';
            });
            $('#TransactionsForPrint').val(transactions);
        },
