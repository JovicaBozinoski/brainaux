        setAction = function (formId, actionid, event) {
            var form = $("#form_" + formId);
            var tempElement = $("<input type='hidden'/>");
            //debugger;
            tempElement.attr("name", actionid).val(actionid);
            tempElement.attr("id", actionid).val("ActionId");
            tempElement.appendTo(form);

            if (event != undefined && event != null) {

                //remove if exist
                if ($('#ChangeFieldId').length != 0) {
                    $('#ChangeFieldId').remove();
                }
                var changeFieldElement = $("<input type='hidden'/>");
                changeFieldElement.attr("name", "ChangeFieldId");
                if (event.target.id)
                    changeFieldElement.attr("id", "ChangeFieldId").val(event.target.id);
                else
                    changeFieldElement.attr("id", "ChangeFieldId").val(event.target.name);

                changeFieldElement.appendTo(form);
            }


            form.submit();
        },
        setClientAction = function (formId, element) {

            var form = $("#form_" + formId);
            var tempElement = $("<input type='hidden'/>");
         

            if (element != undefined && element != null) {

                var inputField = $("input[type='hidden'][name='"+element+"']");

                if (inputField.length > 0) {
                    inputField.remove();
                    console.log("Input field removed.");
                } 
                 
 
                var changeFieldElement = $("<input type='hidden'/>");
                changeFieldElement.attr("name", element);
                                

                changeFieldElement.appendTo(form);

               
                 
            }
        },
        checkMBankActivation = function (userRequestId, redirectUrl) {
            $.ajax({
                url: currentRootUrl + "Csp/checkMBankActivation",
                type: "POST",
                data: {
                    userRequestId: userRequestId
                },
                cache: false,
                success: function (response) {
                    clearInterval(window.CheckMBankActivationStatus);
                    if (response.Status.AcknowledgeType == 0) {
                        window.location.href = redirectUrl;
                    } else {
                        window.CheckMBankActivationStatus = setInterval(function () {
                            iBank.Forms.CheckMBankActivation(userRequestId, redirectUrl);
                        }, 5000);
                    }
                }
            });
        },
        getLongRunningTaskStatus = function (taskid, formId, actionId) {

            $.ajax({
                url: currentRootUrl + "DpsTransferFunds/GetLongRunningTaskStatus",
                dataType: "json",
                type: "POST",
                data: {
                    taskid: taskid
                },
                success: function (data) {

                    if (data.Completed === true) {
                        clearInterval(window.CheckLongRunningTaskStatus);
                        iBank.Payment.SetAction(formId, actionId);
                    }
                    $("#StateStatusMessage").text(data.TransitionDescription);


                    for (i = 0; i < 3; i++) {
                        $("#StateStatusMessage").fadeTo('slow', 0.5).fadeTo('slow', 1.0);
                    }



                },
                error: function () {

                }
            });
        },
        getCoreDetails = function (trackingId) {
            $.ajax({
                url: currentRootUrl + "AutoRefresh/GetCoreDetails",
                dataType: "json",
                type: "POST",
                data: {
                    trackingId: trackingId
                },
                success: function (data) {
                    if (data.Status.AcknowledgeType == 0 || data.Status.AcknowledgeType == 1) {
                        if ((data.POStatus != '-10' && data.CoreStatus != '')) {
                            clearInterval(window.UpdateCoreDetails);
                            $("#ProcesStatusMessage").fadeOut('slow', function () {
                                $("#ProcesStatusMessage").text(data.Message);

                                if (data.CoreStatus >= 0 && data.CoreStatus < 81) {
                                    $("#ProcesStatusMessage").css("background-color", "#DFF0D8")
                                }
                                else {
                                    $("#ProcesStatusMessage").css("background-color", "#F2DEDE")
                                }

                                $(this).fadeIn('slow');
                            });
                        } else if (data.POStatus == '-2' || data.POStatus == '-1') {
                            clearInterval(window.UpdateCoreDetails);
                        }
                    }
                },
                error: function () {

                }
            });
        },
