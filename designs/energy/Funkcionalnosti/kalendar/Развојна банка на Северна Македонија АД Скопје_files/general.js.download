        redistributeMtokenDevice_Succeed = function (response) {
            //$('#mainContent .btn').removeAttr('disabled');

            if (response.mTokenInfo == null || response.mTokenInfo.MTokenSerialNumber == null || response.mTokenInfo.MTokenSerialNumber == "") {
                $("#error").show();
                $("#info").hide();
                $("#response-msg").addClass("error").show();
                $("#response-message").html("Неуспешна редистрибуција!");
            }
            else {
                $("#error").hide();
                $("#info").show();
                $("#response-msg").removeClass("error").show();
                $("#response-message").html("Успешна редистрибуција!");

                //  $("#mtokenPhoneType").html(mTokenInfo.MTokenPhoneType);
                $("#mTokenPhoneNumber").html(response.mTokenInfo.MTokenPhoneNumber);
                $("#mTokenRegisteredDate").html(response.mTokenInfo.MTokenRegisteredDate);
                $("#mTokenRedistributedDate").html(response.mTokenInfo.MTokenRedistributedDate);
                $("#mTokenActivationDate").html(response.mTokenInfo.MTokenActivationDate);
                // console.log(rowCount);
            }
            var $box = $("#application-settings");
