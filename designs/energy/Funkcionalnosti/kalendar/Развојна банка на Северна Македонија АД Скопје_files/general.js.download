                }
            });
        },
        calculateOnlineLoanDetails = function () {
            var iznosKredit = $("#LoanAmount").val();

            var period = $("#InstallmentsNumber").val();

            var kamatnaStapka = parseFloat($("#InterestRate").val().replace(",", "."));

            document.getElementById("UsAmbitions").value = iznosKredit; //Iznos na kredit
            document.getElementById("RepaymentPeriod").value = period; //Rok na otplata
            document.getElementById("InterestRate").value = kamatnaStapka + "%"; //Kamatna stapka

            var V = (1 + (kamatnaStapka / 12) / 100);
            var T = (-(period / 12) * 12);

            var diznos = iznosKredit / 100;

            var result = (diznos * (kamatnaStapka / 12)) / (1 - Math.pow(V, T));

            var mesecnaRata = Math.ceil(result);
            var vkupnoZaVrakanje = Math.ceil(mesecnaRata * period);
            var vkupnaKamata = Math.ceil(vkupnoZaVrakanje - iznosKredit);

            document.getElementById("MonthlyInstallment").value = mesecnaRata; //Mesecna rata
            document.getElementById("LoanInterest").value = vkupnaKamata; //Vkupna kamata
            document.getElementById("TotalForReturn").value = vkupnoZaVrakanje; //Vkupno za vrakanje
        },
        calculateOnlineLoanDetailsV2 = function () {

            var iznosKredit = $("#LoanAmount").val();
            var period = $("#InstallmentsNumber").val();
            var kamatnaStapka = parseFloat($("#InterestDynamic").val().replace(",", "."));

            var p = kamatnaStapka; //Kamatna stapka
            var m = 12; //Konstanta
            var s = 1 + (p / (m * 100));
            var G = iznosKredit; //Iznos na kreditot
            var n = period; //Broj na rati

            var mesecnaRata = G * ((Math.pow(s, n) * (s - 1)) / (Math.pow(s, n) - 1));

            mesecnaRata = Math.round(mesecnaRata);
            var vkupnoZaVrakanje = Math.round(mesecnaRata * period);
            var vkupnaKamata = Math.round(vkupnoZaVrakanje - iznosKredit);

            document.getElementById("MonthlyInstallmentDynamic").value = mesecnaRata; //Mesecna rata
            document.getElementById("TotalInterestAmountDynamic").value = vkupnaKamata; //Vkupna kamata
            document.getElementById("TotalForReturnDynamic").value = vkupnoZaVrakanje; //Vkupno za vrakanje
        },
        calculateBillPaymentAmount = function () {
            var bills = $("#Invoices").val();
            var amount = 0.00;

            var hasBills = bills != null;
            if (hasBills) {
                for (i = 0; i < bills.length; i++) {
                    var amountBill = bills[i].split("^");
                    amount += parseInt(amountBill[2]);
                }
            }

            $("#Amount").val(amount.toFixed(2));

        },
        calculateBillPaymentAmount2 = function () {
            var bills = $("#Invoices").val();
            var amount = 0.00;

            var hasBills = bills != null;
            if (hasBills) {
                for (i = 0; i < bills.length; i++) {
                    var amountBill = bills[i].split("^");
                    amount += parseInt(amountBill[1]);
                }
            }

            $("#Amount").val(amount.toFixed(2));

        },
