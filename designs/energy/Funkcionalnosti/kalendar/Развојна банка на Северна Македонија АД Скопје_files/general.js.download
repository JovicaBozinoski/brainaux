        handleFailure = function (xhr, status, error) {

            console.log(xhr.status);
            console.log(status);
            console.log(error);

            iBank.Forms.HideFormSpinner();

            if (xhr.status === 401) {

                window.location.reload(1);

            }

            if (xhr.status === 404) {


                $('#showGeneralError').show();

            }

            if (xhr.status === 403) {

                $('#showGeneralError').show();

                console.log(xhr);

            }
        },
        clearValidationSummary = function (formId) {
            var container = $('#' + formId).find('[data-valmsg-summary="true"]');
            var list = container.find('ul');
            if (list && list.length) {
                list.empty();
                container.addClass('validation-summary-valid').removeClass('validation-summary-errors');
            }
        },
        setFormFieldValueAndSubmitForm = function (formId, fieldId, value) {
            var form = $("#form_" + formId);
            form.find("#" + fieldId).val(value);
            form.validate();
            if (form.valid()) {
                form.submit();
            }
        },
        setSortingAndSubmitForm = function (sortColumn, sortAscending, formId) {
            var form = $("#form_" + formId);
            form.find("#SortColumn").val(sortColumn);
            form.find("#SortDirection").val(sortAscending);
            form.submit();
        },
        amountConditionChanged = function (value) {
            $("#AmountFrom").val('');
            $("#Amount").val('');
            $("#AmountTo").val('');
            switch (value) {
                case "-1":
                    $("#AmountTo").parent().slideDown(function () {
                        $("#AmountFrom").parent().slideUp(function () {
                            $("#Amount").parent().slideUp(function () {
                                resizeFormModal();
                            });
                        });
                    });
                    break;
                case "0":
                    $("#Amount").parent().slideDown(function () {
                        $("#AmountFrom").parent().slideUp(function () {
                            $("#AmountTo").parent().slideUp(function () {
                                resizeFormModal();
                            });
                        });
                    });
                    break;
                case "1":
                    $("#AmountFrom").parent().slideDown(function () {
                        $("#AmountTo").parent().slideUp(function () {
                            $("#Amount").parent().slideUp(function () {
                                resizeFormModal();
                            });
                        });
                    });
                    break;
                case "2":
                    $("#AmountFrom").parent().slideDown(100, function () {
                        $("#AmountTo").parent().slideDown(function () {
                            $("#Amount").parent().slideUp(function () {
                                resizeFormModal();
                            });
                        });
                    });
                    break;
                default:
                    $("#AmountFrom").parent().slideUp(100, function () {
                        $("#AmountTo").parent().slideUp(function () {
                            resizeFormModal();
                        });
                    });
                    break;
            }
        },
        getCultureLink = function (cultureName) {
            var currentLocation = window.location.href;
            if (currentLocation.indexOf("Language") != -1)
                currentLocation = currentLocation.substring(0, currentLocation.indexOf("Language") - 1);
            if (currentLocation.indexOf("?") == -1)
                currentLocation = currentLocation + "?Language=" + cultureName;
            else
                currentLocation = currentLocation + "&Language=" + cultureName;
            window.location.href = currentLocation;
        },
        redirect = function (href) {
            window.location = href;
        },
        reloadNominalAccounts = function () {
            var accountId = $('#AccountID').val();
            $.ajax({
                url: currentRootUrl + "Fps/TransactionsSwitchAccount?accountId=" + accountId,
                type: "POST",
                data: { accountId: accountId },
                dataType: "JSON",
                cache: false,
                success: function (response) {
                    $("#NominalAccount").empty();
                    $("#NominalAccount").append("<option value=''></option>");
                    for (var i = 0; i < response.length; i++) {
                        $("#NominalAccount").append("<option value='" + response[i].Value + "' " + " data-content='" + response[i].Text + "'></option>");
                    }
                    $("#NominalAccount").selectpicker('refresh');
                    $("#NominalAccount").selectpicker('refresh');
                }
            });
        },
        toggleFilter = function () {
            if ($('#form-holder-modal').length > 0) {
                if ($(window).width() < lg_md_border && $('#form-holder-modal').html().trim() === "") {
                    $('#form_' + currentForm).appendTo($('#form-holder-modal'));
                    $('.form-inline .form-group').css('display', 'block');
                    $('#form-holder').hide();
                    $('#filter-button').show();
                }
                if ($(window).width() >= lg_md_border && $('#form-holder').html().trim() == "") {
                    $('#form_' + currentForm).appendTo($('#form-holder'));
                    $('.form-inline .form-group').css('display', 'inline-block');
                    $('#form-holder').show();
                    $('#filter-button').hide();
                }
            }
        },
        toggleUserTemplates = function () {
            if ($('#user-templates-holder-modal').length > 0) {
                if ($(window).width() < lg_md_border && $('#user-templates-holder-modal').html().trim() === "") {
                    $('#templatesControllerBody').appendTo($('#user-templates-holder-modal'));
                    $('.form-inline .form-group').css('display', 'block');
                    $('#templates-holder').hide();
                    $('#templates-button').show();
                }
                if ($(window).width() >= lg_md_border) {
                    $('#templatesControllerBody').appendTo($('#templates-holder'));
                    $('.form-inline .form-group').css('display', 'inline-block');
                    $('#templates-holder').show();
                    $('#templates-button').hide();
                }
            }
        },
        validateForm = function (formId) {
            var $validator = $("#form_" + formId).validate();
            $validator.resetForm();
            if (!$("#form_" + formId).valid())
                $('#ValidationErrors').slideDown();
            else
                $('#ValidationErrors').slideUp();
        },
        setCurrentForm = function (formId) {
            currentForm = formId;
            var height = $('#form_' + formId).height() + 100;
            $('#form-holder-modal').css('height', height + 'px');
            $("#right-menu").on("shown.bs.modal", function () {
                if (height < 300)
                    $('#form-holder-modal').css('overflow', 'visible');
            });
            //$("#filter-button").show();
        },
        setCurrentItem = function (curr) {
            currentItem = curr;
        },
