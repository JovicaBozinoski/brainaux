            $box.find('.widget-box-overlay').remove();
        },

        activateMtokenDevice_Succeed = function (response) {
            $('#mainContent .btn').removeAttr('disabled');
            if (response.mTokenInfo.MTokenSerialNumber == null || response.mTokenInfo.MTokenSerialNumber == "") {
                $("#error").show();
                $("#info").hide();
                $("#response-msg").addClass("error").show();
                $("#response-message").html("Неуспешна активација!");
            }
            else {
                $("#error").hide();
                $("#info").show();
                $("#response-msg").removeClass("error").show();
                $("#response-message").html("Успешна активација!");

                $("#mtokenPhoneType").html(response.mTokenInfo.MTokenPhoneType);
                $("#mTokenPhoneNumber").html(response.mTokenInfo.MTokenPhoneNumber);
                $("#mTokenRegisteredDate").html(response.mTokenInfo.MTokenRegisteredDate);
                $("#mTokenRedistributedDate").html(response.mTokenInfo.MTokenRedistributedDate);
                $("#mTokenActivationDate").html(response.mTokenInfo.MTokenActivationDate);

                $(".mtokenLink").hide();
                $(".mtokenDevices").show();
                // console.log(rowCount);
            }
            var $box = $("#application-settings");
            $box.removeClass('position-relative');
            $box.find('.widget-box-overlay').remove();
        },

        getData = function (url, widgetId) {
            showWidgetSpinner(widgetId);
            $.ajax({
                timeout: 30000,
                url: url,
                type: "GET",
                cache: false,
                success: function (response) {
                    var $box = $("#" + widgetId);
                    $box.find(".widget-body").replaceWith(response);
                    hideWidgetSpinner(widgetId);
                    window.accountCounter++;
                },
                error: function () {
                    var $box = $("#" + widgetId);
                    $box.find(".widget-body").replaceWith("<div class='widget-body'></div>");
                    hideWidgetSpinner(widgetId);
                }
            });
        },
        getView = function (url, widgetId) {
            showWidgetSpinnerSimple(widgetId);
            $.ajax({
                timeout: 30000,
                url: url,
                type: "GET",
                cache: false,
                success: function (response) {
                    var $box = $("#" + widgetId);
                    $box.replaceWith(response);
                    hideWidgetSpinnerSimple(widgetId);
                    window.accountCounter++;
                },
                error: function () {
                    var $box = $("#" + widgetId);
                    $box.find(".widget-body").replaceWith("<div class='widget-body'></div>");
                    hideWidgetSpinnerSimple(widgetId);
                }
            });
        },
