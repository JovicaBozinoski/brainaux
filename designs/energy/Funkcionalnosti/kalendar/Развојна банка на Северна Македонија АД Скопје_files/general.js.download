        validateMicroblinkDocument = function (recognitionResults) {

            const dateOfIssue = recognitionResults.dateOfIssue;

            const dateOfExpiry = recognitionResults.dateOfExpiry;
            
            if (dateOfIssue == undefined) {

                return 0;
            }
            if (dateOfExpiry == undefined) {

                return 0;
            }

            console.log('dateOfIssue successfullyParsed', dateOfIssue.successfullyParsed);

            if (!dateOfIssue.successfullyParsed) {

                return 0;
            }

            console.log('dateOfExpiry successfullyParsed', dateOfIssue.successfullyParsed);
            if (!dateOfExpiry.successfullyParsed)
            {                
                return 0;
            }

            var dateTo = new Date(dateOfExpiry.year, dateOfExpiry.month, dateOfExpiry.day);
            
            var currentDate = new Date();

            if (dateTo > currentDate) {

                console.log('Document valid!');

                return 1;

            } else {

                console.log('Document expired!');

                return 0;
            }
            
        },
        initMicroBlink = function (recognizer, licence, root, isMobileDevice) {

            console.log('Current recoginzer ', recognizer);

            const blinkId = document.querySelector("blinkid-in-browser");

            blinkId.recognizers = [recognizer];


            blinkId.licenseKey = licence;
            blinkId.engineLocation = root + 'scripts/microblink/resources';
            blinkId.workerLocation = root + 'scripts/microblink/resources/BlinkIDWasmSDK.worker.min.js';


            blinkId.cameraId = null;
            blinkId.scanFromCamera = false;
            blinkId.thoroughScanFromImage = false;

            blinkId.scanFromImage = true;

            blinkId.allowHelloMessage = true;
            blinkId.hideFeedback = true;
            blinkId.hideLoadingAndErrorUi = true;

            blinkId.translations = {
                'action-message': 'Избери слики од галерија',
                'process-image-box-first': 'Предна страна од документ',
                'process-image-box-second': 'Задна страна од документ',
                'process-image-box-add': 'Прикачи',
                'process-image-upload-cta': 'Прикачи',
                'action-alt-camera': 'test',
                'action-alt-gallery': 'Избери слика од галерија',
                'feedback-scan-unsuccessful':'Проблем при скенирање на документот, ве молиме обидете се потвторно!'

            }

            if (recognizer == 'BlinkIdMultiSideRecognizer') {

                blinkId.recognizerOptions = {
                    'BlinkIdMultiSideRecognizer': {
                        'returnFullDocumentImage': true,
                        'saveCameraFrames': false,
                        'returnFaceImage': true,
                        'returnSignatureImage': true,
                        'returnEncodedSignatureImage': true,
                        'returnEncodedFaceImage': true,
                        'returnEncodedFullDocumentImage': true

                    }
                }

            } else {


                blinkId.recognizerOptions = {

                    'BlinkIdSingleSideRecognizer': {
                        'returnFullDocumentImage': true,
                        'returnFaceImage': true,
                        'saveCameraFrames': false,
                        'returnSignatureImage': true,
                        'returnEncodedSignatureImage': true,
                        'returnEncodedFaceImage': true,
                        'returnEncodedFullDocumentImage': true

                    }
                }

            }


            blinkId.addEventListener(

                "fatalError",
                (ev) => {

                    console.log("fatalError", ev.detail);
                    iBank.Forms.ShowMicroBlinkProcessingError('Fatal error loading microblink control please contact Bank!');
                }
            );

            blinkId.addEventListener(

                "ready",
                (ev) => {
                    console.log("ready", ev.detail)

                    if (isMobileDevice == 'False') {
                        var element = document.querySelector("blinkid-in-browser")
                            .shadowRoot.querySelector("mb-container")
                            .querySelector('mb-component').
                            shadowRoot.querySelector('mb-screen#mb-screen-action')
                            .querySelector('div.action-buttons')
                            .querySelector('mb-button')
                            .shadowRoot.querySelector("button[title='test']");




                        if (element) {
                            element.remove();
                        }
                    }
                


                }
            );

            blinkId.addEventListener(

                "scanError",
                (ev) => {
                    console.log("scanError", ev.detail);

                    iBank.Forms.ShowMicroBlinkProcessingError('Проблем при скенирање на документот, ве молиме изберете валиден документ и следете ги упатствата!');

                }
            );

            blinkId.addEventListener(

                "scanSuccess",
                (ev) => {



                    const recognitionResults = ev.detail.recognizer;

                    const multiSideGenericIDRecognizer = recognitionResults;


                    var isValid = iBank.Forms.ValidateMicroblinkDocument(recognitionResults);



                    if (isValid == 1) {
                        console.log(recognitionResults);


                        var imgFrontElement = document.getElementById('frontImage');
                        var imgFaceElement = document.getElementById('faceImage');
                        var imgBackElement = document.getElementById('backImage');







                        const personalIdNumber =
                            multiSideGenericIDRecognizer.personalIdNumber.latin ||
                            multiSideGenericIDRecognizer.personalIdNumber.cyrillic ||
                            multiSideGenericIDRecognizer.personalIdNumber.arabic;

                        const documentNumber =
                            multiSideGenericIDRecognizer.documentNumber.latin ||
                            multiSideGenericIDRecognizer.documentNumber.cyrillic ||
                            multiSideGenericIDRecognizer.documentNumber.arabic ||
                            multiSideGenericIDRecognizer.mrz.documentNumber;


                        const documentTypeOut = multiSideGenericIDRecognizer.mrz.documentType;

                        console.log('personalIdNumber', personalIdNumber);
                        console.log('documentNumber', documentNumber);
                        console.log('documentTypeOut', documentTypeOut);

                        console.log(multiSideGenericIDRecognizer.faceImage);

                        if (documentTypeOut == 1 && recognizer == 'BlinkIdMultiSideRecognizer') {

                            clearMicroBlinkImages(1);

                            var front = new Blob([multiSideGenericIDRecognizer.fullDocumentFrontImage.encodedImage], { type: 'image/jpeg' });
                            var back = new Blob([multiSideGenericIDRecognizer.fullDocumentBackImage.encodedImage], { type: 'image/jpeg' });
                            var face = new Blob([multiSideGenericIDRecognizer.faceImage.encodedImage], { type: 'image/jpeg' });
                            // Add more blobs as needed

                            // Construct FormData and append the Blobs
                            var formData = new FormData();
                            formData.append('file_front', front, 'file_front.jpg');
                            formData.append('file_back', back, 'file_back.jpg');
                            formData.append('file_face', face, 'file_face.jpg');

                            formData.append('documentTypeId', String(documentTypeOut));

                            iBank.Forms.UploadMicroblinkDocuments(formData);

                            $('#backImage').show();


                            var dataFrontUrl = URL.createObjectURL(front);
                            imgFrontElement.src = dataFrontUrl;
                            //imgFrontElement.style = "width:40%";


                            var dataBackUrl = URL.createObjectURL(back);
                            imgBackElement.src = dataBackUrl;
                            //imgBackElement.style = "width:40%";


                            var dataFaceUrl = URL.createObjectURL(face);
                            imgFaceElement.src = dataFaceUrl;



                            if (imgFrontElement) {

                                $('#resultsBlink').show();
                                $("#outputBlink").show();
                                iBank.Forms.HideMicroBlinkProcessingError();

                            }

                        } else if (documentTypeOut == 2 && recognizer == 'BlinkIdSingleSideRecognizer') {

                            clearMicroBlinkImages(2);

                            var front = new Blob([multiSideGenericIDRecognizer.fullDocumentImage.encodedImage], { type: 'image/jpeg' });
                            var face = new Blob([multiSideGenericIDRecognizer.faceImage.encodedImage], { type: 'image/jpeg' });



                            $('.backImage').remove();

                            // Construct FormData and append the Blobs
                            var formData = new FormData();
                            formData.append('file_front', front, 'file_front.jpg');
                            formData.append('file_face', face, 'file_face.jpg');
                            formData.append('documentTypeId', String(documentTypeOut));

                            iBank.Forms.UploadMicroblinkDocuments(formData);

                            var imgFrontElement = document.getElementById('frontImage');
                            var dataFrontUrl = URL.createObjectURL(front);
                            imgFrontElement.src = dataFrontUrl;

                            var imgFaceElement = document.getElementById('faceImage');
                            var dataFaceUrl = URL.createObjectURL(face);
                            imgFaceElement.src = dataFaceUrl;

                            if (imgFrontElement) {
                                $('#resultsBlink').show();
                                $("#outputBlink").show();
                                iBank.Forms.HideMicroBlinkProcessingError();
                            }
                        } else {


                            if (documentTypeOut == 2 && recognizer == 'BlinkIdMultiSideRecognizer') {

                                iBank.Forms.ShowMicroBlinkProcessingError('Невалиден документ! Ве молиме изберете валидна Лична Карта!');

                            } else if (documentTypeOut == 1 && recognizer == 'BlinkIdSingleSideRecognizer') {

                                iBank.Forms.ShowMicroBlinkProcessingError('Ве молиме изберете валиден Пасош!');

                            } else if (documentTypeOut == 0 && recognizer == 'BlinkIdMultiSideRecognizer') {

                                iBank.Forms.ShowMicroBlinkProcessingError('Невалиден документ! Ве молиме изберете валидна Лична Карта!');

                            } else if (documentTypeOut == 0 && recognizer == 'BlinkIdSingleSideRecognizer') {
                                iBank.Forms.ShowMicroBlinkProcessingError('Невалиден документ! Ве молиме изберете валиден Пасош!');
                            }


                        }
                        console.log("BlinkID SingleSide recognizer results", recognitionResults);
                        console.log("scanSuccess", ev.detail)

                    } else {
                        iBank.Forms.ShowMicroBlinkProcessingError('Невалиден документ, документот е истечен!');
                    }


                }
            );

            blinkId.addEventListener(

                "feedback",
                (ev) => {
                    console.log("feedback", ev.detail)

                    var initialRecognizerState = $('input[name="RadioPassportOrId"]:checked').val();
                    console.log('ON FEEDBACK ERROR', initialRecognizerState);
                    if (ev.detail.state == "FEEDBACK_ERROR" && initialRecognizerState == '1') {
                        window.location.reload();
                    }
                }
            );

        },
        showMicroBlinkProcessingError = function (error) {

            /// debugger;

            $('#resultsBlink').show();
            $('#resultError').text(error);
            $('#showError').show();
            $("#outputBlink").hide();

            var imgFrontElement = document.getElementById('frontImage');

            if (imgFrontElement.src!='') {
                iBank.Forms.RemoveMicroblinkDocuments();
            } else {
                console.log('Немаше што да се избрише');
            }

            
        },
        hideMicroBlinkProcessingError = function () {

            $('#resultsBlink').show();
            $('#resultError').text('');
            $('#showError').hide();
            $("#outputBlink").show();
        };
    return {
        Init: init,
        InitMicroBlink: initMicroBlink,
        ShowMicroBlinkProcessingError: showMicroBlinkProcessingError,
        ValidateMicroblinkDocument: validateMicroblinkDocument,
        HideMicroBlinkProcessingError: hideMicroBlinkProcessingError,
        RemoveMicroblinkDocuments: removeMicroblinkDocuments,
        ShowWidgetSpinnerNew: showWidgetSpinnerNew,
        HideWidgetSpinnerNew: hideWidgetSpinnerNew,
        ShowWidgetSpinner: showWidgetSpinner,
        HideWidgetSpinner: hideWidgetSpinner,
        ShowWidgetSpinnerWithText: showWidgetSpinnerWithText,
        ShowWidgetSpinnerSimple: showWidgetSpinnerSimple,
        HideWidgetSpinnerSimple: hideWidgetSpinnerSimple,
        ShowWidgetSpinnerDevice: showWidgetSpinnerDevice,
        ShowLoader: showLoader,
        HideLoader: hideLoader,
        DeleteMbankDevice_Succeed: deleteMbankDevice_Succeed,
        DeleteMbankDevice_Failed: deleteMbankDevice_Failed,
        DeleteMtokenDevice_Failed: deleteMtokenDevice_Failed,
        DeleteMtokenDevice_Succeed: deleteMtokenDevice_Succeed,
        RedistributeMtokenDevice_Succeed: redistributeMtokenDevice_Succeed,
        ActivateMtokenDevice_Succeed: activateMtokenDevice_Succeed,
        GetData: getData,
        GetView: getView,
        ShowFormSpinner: showFormSpinner,
        HideFormSpinner: hideFormSpinner,
        CheckAuthentication: checkAuthentication,
        HandleFailure: handleFailure,
        ClearValidationSummary: clearValidationSummary,
        SetFormFieldValueAndSubmitForm: setFormFieldValueAndSubmitForm,
        SetSortingAndSubmitForm: setSortingAndSubmitForm,
        AmountConditionChanged: amountConditionChanged,
        GetCultureLink: getCultureLink,
        Redirect: redirect,
        ReloadNominalAccounts: reloadNominalAccounts,
        ToggleFilter: toggleFilter,
        ToggleUserTemplates: toggleUserTemplates,
        BlockPage: blockPage,
        UnblockPage: unblockPage,
        ValidateForm: validateForm,
        SetCurrentForm: setCurrentForm,
        SetCurrentItem: setCurrentItem,
        TransactionDetailsDialog: transactionDetailsDialog,
        RetailTransactionDetailsDialog: retailTransactionDetailsDialog,
        PaymentOrderDetailsDialog: paymentOrderDetailsDialog,
        SavingsDetailsDialog: savingsDetailsDialog,
        GroupPaymentOrderDetailsDialog: groupPaymentOrderDetailsDialog,
        RemotePaymentOrderDetailsDialog: remotePaymentOrderDetailsDialog,
        CMStransactionDetailsDialog: cmstransactionDetailsDialog,
        FeeDetailsDialog: feeDetailsDialog,
        IncomeDetailsDialog: incomeDetailsDialog,
        IncomeRetailDetailsDialog: incomeRetailDetailsDialog,
        FpsTransactionDetailsDialog: fpsTransactionDetailsDialog,
        NonresidentTransactionDetailsDialog: nonresidentTransactionDetailsDialog,
        NonresidentSwiftDialog: nonresidentSwiftDialog,
        FpsSwiftDialog: fpsSwiftDialog,
        RetSwiftDialog: retSwiftDialog,
        FpsExchangeOfferAction: fpsExchangeOfferAction,
        ReloadCardNumbers: reloadCardNumbers,
        ReloadPaymentAccounts: reloadPaymentAccounts,
        SetAction: setAction,
        SetClientAction: setClientAction,
        CheckSessionExpireStatus: checkSessionExpireStatus,
        GetCoreDetails: getCoreDetails,
        GetLongRunningTaskStatus: getLongRunningTaskStatus,
        GetCoreDetailsPackage: getCoreDetailsPackage,
        CheckMBankActivation: checkMBankActivation,
        ShowErrorDialog: showErrorDialog,
        ShowSuccessDialog: showSuccessDialog,
        AddToAddressBook: addToAddressBook,
        CalculateOnlineLoanDetails: calculateOnlineLoanDetails,
        CalculateOnlineLoanDetailsV2: calculateOnlineLoanDetailsV2,
        CalculateBillPaymentAmount: calculateBillPaymentAmount,
        GetMaskedName: getMaskedName,
        UploadMicroblinkDocuments: uploadMicroblinkDocuments,
        AddRow: addRow,
        RemoveRow: removeRow,
        UpdateNotificationStatus: updateNotificationStatus

    };
};

iBank.Payment = new function () {
    var count = 0,
        init = function () {
            $('#checkAll').on('click', function () {
                if ($(this).is(':checked'))
                    $('.col-paymentorders-check .ace').prop('checked', true);
                else
                    $('.col-paymentorders-check .ace').prop('checked', false);
                countChecked();
            });
            $('.ace').on('click', function () {
                countChecked();
            });
            $('#dueDateChangeBtn').on('click', function () {
                if (count > 0)
                    $('#dueDateWindow').modal();
                else
                    $('#noOrdersWindow').modal();
            });
            $('#deleteOrdersBtn').on('click', function () {
                if (count > 0)
                    $('#deleteWindow').modal();
                else
                    $('#noOrdersWindow').modal();
            });
            $('#notification-container').hide();
            $('#error-container').hide();
        },
        countChecked = function () {
            count = 0;
            $('.col-paymentorders-check .ace').each(function () {
                if ($(this).is(':checked'))
                    count = count + 1;
            });
            if (count > 0)
                $('#orderCount').html(count).show();
            else
                $('#orderCount').hide();
            return count;
        },
        countCheckedPendingInstallments = function () {
            countPendingIntallments = 0;
            $('.col-pendinginstallments-check .ace').each(function () {
                if ($(this).is(':checked'))
                    count = count + 1;
            });
            if (count > 0)
                $('#orderCount').html(count).show();
            else
                $('#orderCount').hide();
            return count;
        },
        countCheckedStatements = function () {
            countStatements = 0;
            $('.col-statementlist-check .ace').each(function () {
                if ($(this).is(':checked'))
                    count = count + 1;
            });
            if (count > 0)
                $('#orderCount').html(count).show();
            else
                $('#orderCount').hide();
            return count;
        },
        changeDueDate = function (formId, url) {
            $('#dueDateWindow').modal('hide').on('hidden.bs.modal', function () {
                iBank.Forms.ShowFormSpinner('loader-container');
                var selectedOrders = '';
                $('.col-paymentorders-check .ace').each(function () {
                    if ($(this).is(':checked'))
                        selectedOrders = selectedOrders + $(this).val() + ',';
                });
                $.ajax({
                    timeout: 30000,
                    url: url,
                    data: { SelectedItems: selectedOrders, DueDate: $('#DueDate').val() },
                    type: 'post',
                    dataType: 'JSON',
                    cache: false,
                    success: function (response) {
                        if (response.success == true) {
                            $('#successMessage').html(response.message);
                            $('#successDialog').modal().on('hidden.bs.modal', function () {
                                $('#' + formId).submit();
                            });
                        } else {
                            iBank.Forms.HideWidgetSpinner('loader-container');
                            $('#errorMessage').html(response.message);
                            $('#errorsDialog').modal();
                        }
                    },
                    error: function () {
                        $('#errorsDialog').modal();
                    }
                });
            });
        },
        deleteOrders = function (formId, url) {
            $('#deleteWindow').modal('hide').on('hidden.bs.modal', function () {
                iBank.Forms.ShowFormSpinner('loader-container');
                var selectedOrders = '';
                $('.col-paymentorders-check .ace').each(function () {
                    if ($(this).is(':checked'))
                        selectedOrders = selectedOrders + $(this).val() + ',';
                });
                $.ajax({
                    timeout: 30000,
                    url: url,
                    data: { SelectedItems: selectedOrders },
                    type: 'post',
                    dataType: 'JSON',
                    cache: false,
                    success: function (response) {
                        if (response.success == true) {
                            $('#successMessage').html(response.message);
                            $('#successDialog').modal().on('hidden.bs.modal', function () {
                                $('#' + formId).submit();
                            });
                        } else {
                            iBank.Forms.HideWidgetSpinner('loader-container');
                            $('#errorMessage').html(response.message);
                            $('#errorsDialog').modal();
                        }
                    },
                    error: function () {
                        $('#errorsDialog').modal();
                    }
                });
            });
        },
        signOrders = function (url, action) {
            if (typeof (action) === 'undefined') action = 'post';
            iBank.Forms.ShowFormSpinner('loader-container');
            var selectedOrders = '';
            $('.col-paymentorders-check .ace').each(function () {
                if ($(this).is(':checked'))
                    selectedOrders = selectedOrders + $(this).val() + ',';
            });
            $.ajax({
                timeout: 30000,
                url: url,
                data: { SelectedItems: selectedOrders },
                type: action,
                dataType: 'html',
                cache: false,
                success: function (response) {
                    iBank.Forms.HideWidgetSpinner('loader-container');
                    $('#mainContent').html(response);
                },
                error: function (request, status, error) {
                    iBank.Forms.HideWidgetSpinner('loader-container');
                    $('#errorsDialog').modal();
                }
            });
        },
        submitAccounts = function (url, action,warningMessage1,warningMessage2,redirectUrl) {
            if (typeof (action) === 'undefined') action = 'post';
            iBank.Forms.ShowFormSpinner('loader-container');
          
            var userAccounts = '';
            var exists = false;
            var errors = '';
            var counter = 0;
            $('.userAccountCheckbox').each(function () {
                exists = true;
                if ($(this).is(':checked')) {
                    userAccounts += $(this).val() + ';';
                    counter = counter + 1;
                }
            });

            if (counter == 0) {
                errors += `<i class="ace-icon fa fa-info-circle bigger-150"></i>&nbsp;&nbsp;`;
                errors += warningMessage1;
            }

            if (counter > 20) {
                errors += `<i class="ace-icon fa fa-info-circle bigger-150"></i>&nbsp;&nbsp;`;
                errors += warningMessage2;
            }

            var dataToSend = {
                accountIds: userAccounts
            }

            if (errors == '') {
                $.ajax({
                    type: action,
                    data: dataToSend,
                    dataType: "JSON",
                    url: url,
                    success: function (result) {
                        window.location.href = redirectUrl;
                        $('#notification-container').show();
                        iBank.Forms.HideFormSpinner('loader-container');
                    },
                    error: function (e) {
                        iBank.Forms.HideFormSpinner('loader-container');
                    }
                });
            }
            else {
                $('#error-container').html(errors);
                $('#error-container').show();
                iBank.Forms.HideFormSpinner('loader-container');
            }
        },
        preparePendingInstallmentsOrder = function (url, action) {
           // debugger;
            if (typeof (action) === 'undefined') action = 'post';
            iBank.Forms.ShowFormSpinner('loader-container');
            var selectedPendingInstallments = '';
            var selectedAmounts = '';
            var selectedDates = '';
            var sourceAccount = $("#sourceAccountCms").html();
            var numOfSelectedPendingInstallments = 0;
            var totalAmount = 0;
            //debugger;
            $('.col-pendinginstallments-check .ace').each(function () {
                if ($(this).is(':checked')) {
                    selectedPendingInstallments = selectedPendingInstallments + $(this).val() + ',';
                    selectedAmounts = selectedAmounts + $(this).attr('amount').replace(/\./g, '').replace(/\,/g, '.').replace('-', '').replace('MKD', '').trim() + ',';
                    selectedDates = selectedDates + $(this).attr('date') + ',';
                    totalAmount = totalAmount + parseFloat($(this).attr('amount').replace(/\./g, '').replace(/\,/g, '.').replace('-', ''));
                    numOfSelectedPendingInstallments++;
                };
                    
            });
            $.ajax({
                timeout: 30000,
                url: url,
                data: {
                    SourceAccount: sourceAccount,
                    NumOfSelectedPendingInstallments: numOfSelectedPendingInstallments,
                    SelectedPendingInstallments: selectedPendingInstallments,
                    SelectedAmounts: selectedAmounts,
                    SelectedDates: selectedDates,
                    TotalAmount: totalAmount
                },
                type: action,
                dataType: 'html',
                cache: false,
                success: function (response) {
                    iBank.Forms.HideWidgetSpinner('loader-container');
                    $("#form-holder").hide();
                    $('#mainContent').html(response);
                },
                error: function (request, status, error) {
                    iBank.Forms.HideWidgetSpinner('loader-container');
                    $('#errorsDialog').modal();
                }
            });
        },
        exportMultipleStatements = function (url, action) {
            // debugger;
            //if (typeof (action) === 'undefined') action = 'post';
            iBank.Forms.ShowFormSpinner('loader-container');
           
            var selectedStatementNumbers = '';
            var selectedYears = '';
            var sourceAccount = $("#Account_ID").val();
            var numOfSelectedStatements = 0;
            var totalAmount = 0;
            //debugger;
            $('.col-statementlist-check .ace').each(function () {
                if ($(this).is(':checked')) {
                    //$(this).next("span").hide();
                    selectedStatementNumbers = selectedStatementNumbers + $(this).attr('statementnumber') + ',';
                    selectedYears = selectedYears + $(this).attr('statementyear') + ',';
                    numOfSelectedStatements++;
                };

            });
            $('#SelectedStatementNumbers').val(selectedStatementNumbers);
            $('#SelectedYears').val(selectedYears);
            $('#ExportMultipleStatementsForm').submit();

            //$.ajax({
            //    timeout: 30000,
            //    url: url,
            //    data: {
            //        SourceAccount: sourceAccount,
            //        NumberOfSelectedStatements: numOfSelectedStatements,
            //        SelectedStatementNumbers: selectedStatementNumbers,
            //        SelectedYears : selectedYears
            //    },
            //    type: action,
            //    dataType: 'html',
            //    cache: false,
            //    success: function (response) {
            //        iBank.Forms.HideWidgetSpinner('loader-container');
            //        $("#form-holder").hide();
            //        $('#mainContent').html(response);
            //    },
            //    error: function (request, status, error) {
            //        iBank.Forms.HideWidgetSpinner('loader-container');
            //        $('#errorsDialog').modal();
            //    }
            //});
        },
        authorizedEvent = function (authorizationId, formId, actionId) {
            $(document).off('transaction-' + authorizationId + '-authorized').on('transaction-' + authorizationId + '-authorized', function () {
                iBank.Payment.SetAction('form_' + formId, actionId);
            });
        },
        setAction = function (formId, actionid) {
            var form = $("#" + formId);
            var tempElement = $("<input type='hidden'/>");
            tempElement.attr("name", actionid).val(actionid);
            tempElement.attr("id", actionid).val("ActionId");
            tempElement.appendTo(form);
            form.submit();
        },
        signOrdersDynamic = function (url, action, processID) {
            if (typeof (action) === 'undefined') action = 'post';
            iBank.Forms.ShowFormSpinner('loader-container');
            var selectedOrders = '';
            $('.col-paymentorders-check .ace').each(function () {
                if ($(this).is(':checked'))
                    selectedOrders = selectedOrders + $(this).val() + ',';
            });
            $.ajax({
                timeout: 30000,
                url: url,
                data: {
                    SelectedItems: selectedOrders,
                    ProcessID: processID
                },
                type: action,
                dataType: 'html',
                cache: false,
                success: function (response) {
                    iBank.Forms.HideWidgetSpinner('loader-container');
                    $('#mainContent').html(response);
                },
                error: function (request, status, error) {
                    iBank.Forms.HideWidgetSpinner('loader-container');
                    $('#errorsDialog').modal();
                }
            });
        };
    return {
        Init: init,
        CountChecked: countChecked,
        ChangeDueDate: changeDueDate,
        DeleteOrders: deleteOrders,
        SignOrders: signOrders,
        SubmitAccounts: submitAccounts,
        AuthorizedEvent: authorizedEvent,
        SetAction: setAction,
        CountCheckedPendingInstallments: countCheckedPendingInstallments,
        PreparePendingInstallmentsOrder: preparePendingInstallmentsOrder,
        CountCheckedStatements: countCheckedStatements,
        ExportMultipleStatements: exportMultipleStatements,
        SignOrdersDynamic: signOrdersDynamic
    };
};

iBank.Dashboard = new function () {
    var rootUrl = '',
        messages,
        init = function (rootUrlExt, messagesExt) {
            rootUrl = rootUrlExt;
            messages = messagesExt;
            $(function () {
                $('.grid-stack').gridstack({
                    always_show_resize_handle: /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent),
                    animate: false,
                    auto: true,
                    float: false,
                    vertical_margin: 10,
                    draggable: {
                        handle: '.widget-header',
                    }
                });
                $('.grid-stack').on('resizestart', function (event) {
                    $(event.target).find('.widget-body').css('opacity', '0');
                });
                $('.grid-stack').on('resizestop', function (event) {
                    $(event.target).find('.widget-body').css('opacity', '1');
                });
                $('.grid-stack').on('change', function (e, items) {
                    if (items != undefined && items && items.length > 0) {
                        var element = items[0].el;
                        redrawWidget(element, items[0].width, items[0].height);
                    }
                });
            });
            (function ($) {
                $.fn.removeClassPrefix = function (prefix) {
                    this.each(function (i, el) {
                        var classes = el.className.split(" ").filter(function (c) {
                            return c.lastIndexOf(prefix, 0) !== 0;
                        });
                        el.className = $.trim(classes.join(" "));
                    });
                    return this;
                };
            }(jQuery));
        },
        redrawWidget = function (element, widthIndex, heightIndex) {
            var height = element.height() - 60;
            element.find('.position-relative').css('height', height + 'px');
            element.find('.mCustomScrollbar ').removeClassPrefix("scroll-").addClass('scroll-' + element[0].id.replace("grid_", "") + '-h' + heightIndex).mCustomScrollbar('update');
            element.find('.table').removeClassPrefix(element[0].id.replace("grid_", ""));
            element.find('.table').addClass(element[0].id.replace("grid_", "") + '-w' + widthIndex);
        },
        drawScrollbar = function (widget) {
            $(widget).mCustomScrollbar({
                theme: 'inset-dark',
                advanced: {
                    updateOnBrowserResize: true,
                    updateOnContentResize: true
                },
            });
        },
        
        getGridArray = function () {
            var widgets = [];
            $('.grid-stack-item').each(function () {
                var widget = {
                    account: $(this).data('account'),
                    id: $(this).data('id'),
                    x: $(this).data('gs-x'),
                    y: $(this).data('gs-y'),
                    width: $(this).data('gs-width'),
                    height: $(this).data('gs-height'),
                };
                widgets.push(widget);
            });
            return widgets;
        },
        setAccount = function (element, account) {
            $(element).attr('data-account', account);
        },
        saveWidgetSelection = function () {
            $('.modal-content').append('<div class="widget-box-overlay"><div class="cssload-container"><div class="cssload-speeding-wheel"></div></div></div>');
            var selection = '';
            $('#choose-widget').find('input[type="checkbox"]').each(function () {
                if ($(this).is(':checked'))
                    selection += $(this).val() + ";";
            });
            var layout = getGridArray();
            $.ajax({
                timeout: 30000,
                url: rootUrl + 'Dashboard/SaveWidgetSelection',
                type: "POST",
                data: { widgets: selection, layout: JSON.stringify(layout), reorder: true },
                dataType: 'json',
                cache: false,
                success: function (response) {
                    if (response.success)
                        window.location.href = rootUrl + 'Dashboard/ReloadPage';
                    else {
                        $('.modal-content').find('.widget-box-overlay').remove();
                        $('#choose-widget').find('.alert').text(response.message);
                    }
                },
                error: function () {
                    $('.modal-content').find('.widget-box-overlay').remove();
                    $('#choose-widget').find('.alert').text(messages[0]);
                }
            });
        },
        saveLayoutSelection = function () {
            iBank.Forms.BlockPage();
            var selection = '';
            $('#choose-widget').find('input[type="checkbox"]').each(function () {
                if ($(this).is(':checked'))
                    selection += $(this).val() + ";";
            });
            var layout = getGridArray();
            $.ajax({
                timeout: 30000,
                url: rootUrl + 'Dashboard/SaveWidgetSelection',
                type: "POST",
                data: { widgets: selection, layout: JSON.stringify(layout), reorder: false },
                dataType: 'json',
                cache: false,
                success: function (response) {
                    if (response.success)
                        window.location.href = rootUrl + 'Dashboard/Index';
                    else
                        iBank.Forms.UnblockPage();
                },
                error: function () {
                    iBank.Forms.UnblockPage();
                }
            });
        };
    return {
        Init: init,
        RedrawWidget: redrawWidget,
        DrawScrollbar: drawScrollbar,
        SaveWidgetSelection: saveWidgetSelection,
        SaveLayoutSelection: saveLayoutSelection,
        SetAccount: setAccount
    };
};

iBank.Calendar = new function () {
    var rootUrl = '',
        messages,
        language = 'mk',
        init = function (languageExt, rootUrlExt, messagesExt) {
            language = languageExt;
            rootUrl = rootUrlExt;
            messages = messagesExt;
            $(document).ready(function () {
                $('#calendar').fullCalendar({
                    firstDay: 1,
                    dayNames: true,
                    lang: languageExt,
                    fixedWeekCount: false,
                    height: $(window).height() - 170,
                    header: {
                        left: '',
                        center: 'title',
                        right: 'today prev,next'
                    },
                    events: function (start, end, timezone, callback) {
                        $.ajax({
                            url: rootUrl + "Calendar/Index",
                            dataType: 'json',
                            cache: false,
                            type: 'post',
                            data: {
                                DateFrom: $('#calendar').fullCalendar('getView').intervalStart.format('DD.MM.YYYY'),
                                DateTo: $('#calendar').fullCalendar('getView').intervalEnd.format('DD.MM.YYYY')
                            },
                            success: function (response) {
                                var events = [];
                                $.each(jQuery.parseJSON(response), function (i, item) {
                                    events.push({
                                        id: item.id,
                                        title: item.title,
                                        start: item.start,
                                        className: item.className
                                    });
                                });
                                callback(events);
                            }
                        });
                    },
                    eventClick: function (calEvent) {
                        getEventDetails(calEvent.id);
                    },
                    dayClick: function (date) {
                        if (!$(this).hasClass('fc-other-month'))
                            createEvent(null, date.format('DD.MM.YYYY'));
                    },
                    eventAfterAllRender: function () {
                        $('.fc-content-skeleton').each(function () {
                            var index = 0;
                            var row = $(this);
                            row.find('table thead tr td').each(function (i) {
                                if (!$(this).hasClass('fc-other-month')) {
                                    index = i + 1;
                                    var date = $(this).data('date');
                                    var color = "";
                                    if ($(this).hasClass('fc-today'))
                                        color = "#ffc";
                                    row.find('table tr td:nth-child(' + index + ')').css('cursor', 'pointer').hover(
                                        function () { row.parent().find('.fc-bg').find('td[data-date="' + date + '"]').css('background-color', 'lightcyan'); },
                                        function () { row.parent().find('.fc-bg').find('td[data-date="' + date + '"]').css('background-color', color); });
                                }
                            });
                        });
                    },
                    dayRender: function (date, cell) {
                        if (!cell.hasClass('fc-other-month')) {
                            var color = "";
                            if (cell.hasClass('fc-today'))
                                color = "#ffc";
                            cell.css('cursor', 'pointer').hover(
                                function () { cell.css('background-color', 'lightcyan'); },
                                function () { cell.css('background-color', color); });
                        }
                    }
                });

                $('.fc-right').prepend('<button class="btn btn-sm btn-primary" type="button" onclick="iBank.Calendar.CreateEvent(null, null);"><i class="ace-icon fa fa-plus"></i>' + messages[0] + '</button>');
            });
        },
        getEventDetails = function (id) {
            $.ajax({
                url: rootUrl + "Calendar/Details",
                type: 'get',
                cache: false,
                data: { id: id },
                success: function (response) {
                    $('#transactionDetails').html(response);
                    $('#transactionDetails').modal();
                }
            });
        },
        createEvent = function (id, date) {
            $.ajax({
                url: rootUrl + "Calendar/Create",
                type: 'get',
                cache: false,
                data: { id: id, date: date },
                success: function (response) {
                    $('#transactionDetails').html(response);
                    $('#transactionDetails').modal();
                }
            });
        },
        deleteEvent = function (id) {
            $.ajax({
                timeout: 30000,
                url: rootUrl + "Calendar/Delete",
                data: { id: id },
                type: 'post',
                dataType: 'JSON',
                cache: false,
                success: function (response) {
                    if (response.success == true) {
                        iBank.Forms.ShowSuccessDialog(response.message);
                        $('#calendar').fullCalendar('refetchEvents');
                    } else {
                        iBank.Forms.ShowErrorDialog(response.message);
                    }
                },
                error: function () {
                    $('#errorsDialog').modal();
                }
            });
        };
    return {
        Init: init,
        CreateEvent: createEvent,
        DeleteEvent: deleteEvent
    };
};

iBank.Helper = new function () {
    var rootUrl = '',
        messages,
        language = 'mk',
        a = { "Q": "Љ", "W": "Њ", "X": "Џ", "E": "Е", "R": "Р", "T": "Т", "Y": "Ѕ", "U": "У", "I": "И", "O": "О", "P": "П", "SH": "Ш", "]": "Ѓ", "A": "А", "S": "С", "D": "Д", "F": "Ф", "G": "Г", "H": "Х", "J": "Ј", "K": "К", "L": "Л", ";": "Ч", "KJ": "Ќ", "\\": "Ж", "Z": "З", "DZ": "Џ", "C": "Ц", "Б": "B", "V": "В", "N": "Н", "M": "М" },
        b = { "Љ": "Q", "Њ": "W", "Е": "E", "Р": "R", "Т": "T", "Ѕ": "Y", "У": "U", "И": "I", "О": "O", "П": "P", "Ш": "SH", "Ѓ": "]", "А": "A", "С": "S", "Д": "D", "Ф": "F", "Г": "G", "Х": "H", "Ј": "J", "К": "K", "Л": "L", "Ч": ";", "Ќ": "KJ", "Ж": "\\", "З": "Z", "Џ": "DZ", "Ц": "C", "Б": "B", "В": "V", "Н": "N", "М": "M" };

    const c = {

             "Q": "Љ", "W": "Њ", "X": "Џ", "E": "Е", "R": "Р", "T": "Т", "Y": "Ѕ",
             "U": "У", "I": "И", "O": "О", "P": "П", "{": "Ш", "}": "Ѓ", "|": "Ж", "A": "А",
             "S": "С", "D": "Д", "F": "Ф", "G": "Г", "H": "Х", "J": "Ј", "K": "К", "L": "Л", ":": "Ч",
             "\"": "Ќ", "Z": "З", "X": "Џ", "C": "Ц", "V": "В", "B": "Б", "N": "Н", "M": "М",
             "q": "љ", "w": "њ", "x": "џ", "e": "е", "r": "р", "t": "т", "y": "ѕ",
             "u": "у", "i": "и", "o": "о", "p": "п", "[": "ш", "]": "ѓ", "\\": "ж", "a": "а",
             "s": "с", "d": "д", "f": "ф", "g": "г", "h": "х", "j": "ј", "k": "к", "l": "л", ";": "ч",
             "'": "ќ", "z": "з", "c": "ц", "v": "в", "b": "б", "n": "н", "m": "м"  
        };

    init = function (rootUrlExt) {
        language = languageExt;
        rootUrl = rootUrlExt;
    },
        transliterate = function (word) {
            var result = '';
            result = word.split('').map(function (char) {
                return c[char] || char;
            }).join('');
            return result;
        };
         
    transliterateToCyrillic = function (element) {

        $(element).val(iBank.Helper.Transliterate($(element).val().toUpperCase()));

    };

    translateLanguage = function (element) {

        element.on('input', function () {
                        
            let currentText = $(this).val();

            let replacedText = currentText.split('').map(function (char) {
                return c[char] || char; 
            }).join('');

            $(this).val(replacedText);
        });

    };

    toUpperTransliterate = function (element) {
        $(element).val(iBank.Helper.Transliterate($(element).val().toUpperCase()));
    };


    stringToColour = function (str) {
        str = str.toUpperCase().trim();
        //console.log(str);
        var hash = 0;
        for (var i = 0; i < str.length; i++) {
            hash = str.charCodeAt(i) + ((hash << 5) - hash);
        }
        var colour = '#';
        for (var j = 0; j < 3; j++) {
            var value = (hash >> (j * 8)) & 0xFF;
            colour += ('00' + value.toString(16)).substr(-2);
        }
        return colour;
    };

    categoryToColour = function (categoryName, categoryId) {
        //if categoryId is not sent or is null
        if (!categoryId) {
            categoryId = "";
        }

        switch (categoryId.toString()) {
            case "1":
                return "#638BB3"; //nedefinirano
            case "2":
                return "#0074D9"; //food
            case "3":
                return "#3C2109"; //reziski
            case "4":
                return "#39CCCC"; //car           
            case "5":
                return "#3D9970"; //investicija
            case "6":
                return "#2ECC40"; //nadomestok
            case "7":
                return "#2B0000"; //danok i taksa
            case "8":
                return "#7FDBFF"; //lekuvanje
            case "9":
                return "#85144b"; //licna nega
            case "10":
                return "#F012BE"; //milenici
            case "11":
                return "#2D383C"; //kukja
            case "12":
                return "#3A539B"; //pazaranje
            case "13":
                return "#315131"; //odmor
            case "14":
                return "#360036"; //prihodi
            case "15":
                return "#FF851B"; //gotovina
            default:
                return stringToColour(categoryName);
        }
    };

    getIconFromCategory = function (categoryId) {
        categoryId = categoryId.trim();
        switch (categoryId) {
            case "1":
                return "fa-question"; //nedefinirano
            case "2":
                return "fa-cutlery"; //food
            case "3":
                return "fa-file-o"; //reziski
            case "4":
                return "fa-car"; //car           
            case "5":
                return "fa-university"; //investicija
            case "6":
                return "fa-circle-thin"; //nadomestok
            case "7":
                return "fa-gavel"; //danok i taksa
            case "8":
                return "fa-hospital-o"; //lekuvanje
            case "9":
                return "fa-life-ring"; //licna nega
            case "10":
                return "fa-paw"; //milenici
            case "11":
                return "fa-home"; //kukja
            case "12":
                return "fa-shopping-cart"; //pazaranje
            case "13":
                return "fa-ship"; //odmor
            case "14":
                return "fa-money"; //prihodi
            case "15":
                return "fa-credit-card"; //gotovina
            default:
                return "fa-user-o";
        }

    };


    return {
        Init: init,
        Transliterate: transliterate,
        TransliterateToCyrillic: transliterateToCyrillic,
        ToUpperTransliterate: toUpperTransliterate,
        TranslateLanguage: translateLanguage,
        StringToColour: stringToColour,
        CategoryToColour: categoryToColour,
        GetIconFromCategory: getIconFromCategory
    };
};