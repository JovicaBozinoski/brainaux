        getMaskedName = function (name, mask) {
            // Во поглед на анонимизацијата на клиентските податоци и во двете опции (плати на пријател и подели сметка) истата би била на следниов начин
            // Адресни податоци (град и општина) не треба да се прикажуваат
            if (TextUtils.isEmpty(name))
                return name;
            if (name.length() < 5) {
                if (name.length() > 2) {
                    return name.substring(0, 2) + Strings.repeat(mask, name.length() - 2);
                } else {
                    return name;
                }
            } else {
                return name.substring(0, 2) + Strings.repeat(mask, name.length() - 3) + name.charAt(name.length() - 1);
            }
        },

        deleteMbankDevice_Succeed = function (response) {
            $('#mainContent .btn').removeAttr('disabled');
            if (!response.response.Success) {
                $("#error").show();
                $("#info").hide();
                $("#response-msg").addClass("error").show();
                $("#response-message").html(response.response.ErrorMessage);
            }
            else {
                $("#" + response.response.HtmlElementId).css("background-color", "red").hide(1000, function () {
                    $(this).remove();
                });
                $("#error").hide();
                $("#info").show();
                $("#response-msg").removeClass("error").show();
                $("#response-message").html(response.response.ResponseMessage);
                var rowCount = $("#mbankDevicesBody tr:last").index();
                if (rowCount == 0) {
                    $(".mbankDevices").hide();
                    $(".mobileLinks").show();
                }
                // console.log(rowCount);
            }
            var $box = $("#application-settings");
            $box.removeClass('position-relative');
            $box.find('.widget-box-overlay').remove();
        },

        deleteMbankDevice_Failed = function (response) {
            $('#mainContent .btn').removeAttr('disabled');
            $("#response-msg").addClass("error").show();
            $("#error").show();
            $("#info").hide();
            $("#response-message").html("Се појави грешка!");
            var $box = $("#application-settings");
            $box.removeClass('position-relative');
            $box.find('.widget-box-overlay').remove();
        },
