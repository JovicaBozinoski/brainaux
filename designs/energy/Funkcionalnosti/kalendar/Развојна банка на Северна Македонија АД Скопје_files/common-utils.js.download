//detekcija za Chrome nativna komponenta
function IsComponentInstaled(extensionId, callback) {
    chrome.runtime.sendMessage(extensionId, {
        message: "installed_component"
    },
		function (reply) {
		    if (reply) {
		        callback(true);
		    } else {
		        callback(false);
		    }
		});
}

var extensionTagId = "";
//Function that checks if the EXTENSION is Avaible
function IsExtensionInstaled(extensionId, callback) {
    extensionTagId = extensionId;
    //Uncomment this when extensions are UPDATED to latest version that include the div with id
    if (CheckExtensionTag()) {  
     //if (typeof TokenSigning !== 'undefined') {
        callback(true);
    }
    else {
        callback(false);
    }
}

